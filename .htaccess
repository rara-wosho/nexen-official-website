RewriteEngine On

# 1. Remove .php from URL (Only for GET requests)
# This prevents the redirect from breaking form submissions
RewriteCond %{REQUEST_METHOD} GET
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 2. Internally map clean URL to .php file
# This checks if the file exists and serves it behind the scenes
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)$ $1.php [L]